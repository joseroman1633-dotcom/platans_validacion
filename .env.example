SECRET_KEY=pon-aqui-una-clave-segura
DEBUG=False
USE_CLOUDINARY=True
ALLOWED_HOSTS=tu-app.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com

# Produccion en Render
DATABASE_URL=postgresql://usuario:password@host:5432/base_de_datos

# Desarrollo local opcional (si no defines DATABASE_URL, se usa sqlite3)
# LOCAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/platans_db

# Cloudinary: usa solo una de estas dos opciones.
# Opcion 1 (recomendada):
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Opcion 2 (variables separadas):
# CLOUDINARY_CLOUD_NAME=<cloud_name>
# CLOUDINARY_API_KEY=<api_key>
# CLOUDINARY_API_SECRET=<api_secret>
